@article{fankhauser2025epistemic,
  title = {Epistemic Horizons From Deterministic Laws: Lessons From a Nomic Toy Theory},
  author = {Fankhauser, Johannes and Gonda, Tom{\\'a}{\\v{s}} and de les Coves, Gemma},
  journal = {Synthese},
  volume = {205},
  pages = {136},
  year = {2025},
  doi = {10.1007/s11229-024-04852-0},
  html = {https://link.springer.com/article/10.1007/s11229-024-04852-0},
  abstract = {Quantum theory has an epistemic horizon, i.e. quantum states imply uncertainty for the outcomes of incompatible measurements. As shown by so-called Spekkens' toy theory, positing an epistemic horizon akin to Heisenberg's uncertainty principle in a classical mechanical setting also leads to a plethora of quantum phenomena. We describe a theory - nomic toy theory - in which information gathering agents are explicitly modelled as physical systems. While the physical state in principle determines the values of all observable of a system, we prove that precisely this epistemic horizon arises from deterministic interactions. Therefore, a physical system cannot be fully accessed, represented, and predicted. The result reconciles us to measurement uncertainty in quantum theory as aspects of the inseparability of subject and object. Significantly, the claims follow despite the theory being essentially classical. Hence, dynamical epistemic horizons may already exist in Newtonian physics.},
  selected = {true}
}

@incollection{fankhauser2023undetectability,
  title = {The (un)detectability of Bohmian trajectories},
  author = {Fankhauser, Johannes},
  booktitle = {Guiding Waves in Quantum Mechanics: One Hundred Years of de Broglie-Bohm Pilot-Wave Theory},
  editor = {Oldofredi, Andrea},
  chapter = {9},
  publisher = {Oxford University Press},
  address = {Oxford},
  year = {2023},
  doi = {10.1093/oso/9780198901853.003.0010},
  html = {https://doi.org/10.1093/oso/9780198901853.003.0010},
  abstract = {Pilot wave theory endows particles with definite positions at all times governed by deterministic dynamics. However, individual particle trajectories are generically undetectable by experiment. This idea might seem to be contested in light of two proposals: weak velocity measurements, allegedly detecting Bohmian trajectories by weakly probing a quantum system without essentially disturbing it, and the so-called surrealistic trajectories experiment. Although both attempts shed light on the nature of Bohmian particles, neither constitute empirical or theoretical evidence in favour or against pilot wave theory. Both instances admit a straightforward standard quantum mechanical interpretation compatible with the predictions of Bohmian theories.}
}

@article{fankhauser2024epistemicboundaries,
  title = {Epistemic Boundaries and Quantum Uncertainty: What Local Observers Can (Not) Predict},
  author = {Fankhauser, Johannes},
  journal = {Quantum},
  volume = {8},
  pages = {1518},
  year = {2024},
  doi = {10.22331/q-2024-11-07-1518},
  html = {https://doi.org/10.22331/q-2024-11-07-1518},
  abstract = {One of quantum theory's salient lessons is its inherent indeterminacy. We formally define and address whether quantum uncertainty could be fundamental or whether post-quantum theories can offer predictive advantage whilst conforming to the Born rule on average. The findings reconcile us to quantum uncertainty as an aspect of limits on Nature's predictability.},
  selected = {true}
}

@phdthesis{fankhauser2022observability,
  title = {Observability and Predictability in Quantum and Post-Quantum Physics},
  author = {Fankhauser, Johannes},
  school = {University of Oxford},
  year = {2022},
  html = {https://ora.ox.ac.uk/objects/uuid:e7c59dac-579c-4ecf-b887-3d315060d144},
  abstract = {I introduce a framework to distinguish the manifest domain of physics from the non-manifest domain of physics and show that many quantum paradoxes rest on ambiguous reasoning about the two domains. I then define and address the question of whether quantum uncertainty could be fundamental or whether post-quantum theories could offer predictive advantage whilst conforming to the Born rule on average.},
  selected = {true}
}

@article{duerr2021weak,
  title = {How (not) to understand weak measurements of velocity},
  author = {Duerr, Patrick M. and Fankhauser, Johannes},
  journal = {Studies in History and Philosophy of Science Part A},
  volume = {85},
  pages = {16--29},
  year = {2021},
  doi = {10.1016/j.shpsa.2020.12.002},
  html = {https://doi.org/10.1016/j.shpsa.2020.12.002},
  abstract = {Weak velocity measurements constitute no new arguments, let alone empirical evidence, in favour of standard de Broglie-Bohm theory. Weak velocity measurements admit of a straightforward standard quantum mechanical interpretation, independent of any commitment to particle trajectories and velocities.}
}

@article{fankhauser2019delayed,
  title = {Taming the Delayed Choice Quantum Eraser},
  author = {Fankhauser, Johannes},
  journal = {Quanta},
  volume = {8},
  pages = {44--56},
  year = {2019},
  doi = {10.12743/quanta.v8i1.88},
  html = {https://doi.org/10.12743/quanta.v8i1.88},
  abstract = {I discuss the delayed choice quantum eraser experiment by drawing an analogy to a Bell-type measurement and giving a straightforward account in standard quantum mechanics. The alleged mystery dissolves once the role of the signal photon is properly taken into account.}
}

@article{fankhauser2024redshift,
  title = {Gravitational redshift revisited: inertia, geometry, and charge},
  author = {Fankhauser, Johannes and Read, James},
  journal = {Studies in History and Philosophy of Science},
  volume = {108},
  pages = {19--27},
  year = {2024},
  doi = {10.1016/j.shpsa.2024.09.001},
  html = {https://doi.org/10.1016/j.shpsa.2024.09.001},
  abstract = {We clarify what gravitational redshift experiments establish. We argue that some results can be accounted for using accelerating frames in special relativity, and that even when more is needed, spacetime curvature is not always the required explanatory resource.}
}

